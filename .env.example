# ============================================================
# REQUERIDO — sin estos valores el bot no arranca
# ============================================================

# Token del bot de Telegram (obtenerlo con @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Tu ID de usuario de Telegram (para restringir acceso)
# Puedes obtenerlo mandando /start a @userinfobot
# Para múltiples usuarios: 123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=your_telegram_user_id_here

# API key de OpenAI
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# ============================================================
# OPCIONAL — los valores por defecto están indicados
# ============================================================

# Modelo de chat (default: gpt-4o-mini)
OPENAI_CHAT_MODEL=gpt-4o-mini

# Modelo de transcripción de audio (default: gpt-4o-transcribe)
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# Ruta al archivo SQLite (default: ./data/assistant.db)
# En Docker este path apunta al volumen montado en /app/data
DATABASE_URL=./data/assistant.db

# Nivel de logs: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Entorno: development | production (default: development)
NODE_ENV=development

# ============================================================
# GOOGLE WORKSPACE (gog CLI) — requiere gog instalado y autenticado
# ============================================================

# Cuenta de Google por defecto (evita pasar --account en cada comando)
# Configura gog primero:
#   gog auth credentials /path/to/client_secret.json
#   gog auth add you@gmail.com --services gmail,calendar,drive,contacts,docs,sheets
GOG_ACCOUNT=you@gmail.com
